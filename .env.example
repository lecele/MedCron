# ============================================================
#  MedCron_Py — Template de Variáveis de Ambiente
#  ✅  Este arquivo É commitado no Git (não tem valores reais)
#  📋  Copie-o para .env e preencha os valores:
#      $ cp .env.example .env
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  ← Apenas se necessário para operações admin

# --- OpenAI (Supervisor Orquestrador + Agente de Visão) ---
OPENAI_API_KEY=sk-...

# --- Google AI (Gemini — Agente de Visão para OCR de receitas) ---
GOOGLE_API_KEY=AIzaSy...

# --- Telegram Bot (Worker de Lembretes) ---
TELEGRAM_BOT_TOKEN=...
TELEGRAM_BOT_USERNAME=MedCron_bot

# --- Configurações da Aplicação ---
ENVIRONMENT=development
APP_NAME=MedCron
APP_VERSION=2.0.0
# Origens permitidas pelo CORS (separe por vírgula)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- MemPalace (Memória de Longo Prazo na VPS) ---
# URL da sua VPS onde o MemPalace está hospedado
MEMPALACE_API_URL=http://SUA_VPS_IP:PORTA


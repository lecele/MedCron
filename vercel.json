{
  "version": 2,
  "builds": [
    {
      "src": "app/main.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "Frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/app/main.py"
    },
    {
      "source": "/(.*)",
      "destination": "/Frontend/$1"
    }
  ],
  "env": {
    "ENVIRONMENT": "production"
  }
}

# ============================================================
#  MedCron_Py — .gitignore
#  ⚠️  SEGURANÇA: Nunca remova .env desta lista!
# ============================================================

# --- Segredos e Variáveis de Ambiente ---
.env
.env.local
.env.*.local
# nunca comitar o service_role key do Supabase
*.service_role_key

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
installed-files.txt
.Python

# --- Ambientes Virtuais ---
venv/
.venv/
env/
ENV/
.env_backup
Pipfile.lock

# --- IDEs e Editores ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Testes e Coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# --- Logs e Dados Temporários ---
*.log
logs/
*.sqlite3
*.db

# --- Node.js (se o frontend React estiver neste repo) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# --- Build do Frontend ---
frontend/dist/
frontend/build/

# --- LangGraph / Cache ---
.langgraph_cache/
.langchain_cache/

# --- Jupyter ---
.ipynb_checkpoints

# --- Vercel ---
.vercel

# --- Arquivos com segredos expostos (nunca commitar) ---
Frontend/1=1
Frontend/openclaw_vps.json
Frontend/b64.txt
